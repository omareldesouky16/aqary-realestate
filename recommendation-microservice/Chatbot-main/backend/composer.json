{
  "name": "aqary/chatbot-backend",
  "description": "Laravel-shaped backend skeleton for Aqary chatbot Phase 1.",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\": "database/",
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "php artisan test --filter=Chat"
  }
}
